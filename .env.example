# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed.

# Buffer personal access token (Buffer > Settings > Apps / developers)
BUFFER_ACCESS_TOKEN=

# Just the spreadsheet ID, the long string from the sheet URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=

# Name of the tab inside the spreadsheet
GOOGLE_SHEET_TAB=Content Calendar

# Path to the Google service-account JSON key (also gitignored)
GOOGLE_CREDENTIALS_PATH=./google-credentials.json

# --- Admin dashboard ( /admin ) -------------------------------------------
# The passphrase that unlocks corealivenessproject.com/admin. This is checked
# server-side by netlify/functions/admin.mjs. In production, set it in Netlify:
#   Site configuration > Environment variables > ADMIN_KEY
# NEVER commit a real value. Use a long, unique passphrase.
ADMIN_KEY=
